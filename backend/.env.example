AI_PROVIDER=ollama
APP_HOST=127.0.0.1
APP_PORT=8000
LLM_TIMEOUT_SECONDS=120
RUNTIME_DIAGNOSTIC_TIMEOUT_SECONDS=2
BALANCE_FOCUSED_INPUT_CHARS=80
BALANCE_DEEP_INPUT_CHARS=280
BALANCE_CODE_CHARS_PER_TOKEN=3
BALANCE_CODE_MIN_TOKENS=1024
BALANCE_CODE_MAX_TOKENS=4096
BALANCE_LIGHT_HISTORY_MESSAGES=4
BALANCE_LIGHT_CONTEXT_CHARS=400
BALANCE_LIGHT_OUTPUT_TOKENS=160
BALANCE_LIGHT_REFLECTION_TOKENS=160
BALANCE_LIGHT_PLANNER_TOKENS=120
BALANCE_FOCUSED_HISTORY_MESSAGES=8
BALANCE_FOCUSED_CONTEXT_CHARS=800
BALANCE_FOCUSED_OUTPUT_TOKENS=360
BALANCE_FOCUSED_REFLECTION_TOKENS=240
BALANCE_FOCUSED_PLANNER_TOKENS=200
BALANCE_DEEP_HISTORY_MESSAGES=14
BALANCE_DEEP_CONTEXT_CHARS=1400
BALANCE_DEEP_OUTPUT_TOKENS=720
BALANCE_DEEP_REFLECTION_TOKENS=360
BALANCE_DEEP_PLANNER_TOKENS=320
BALANCE_GUARDED_HISTORY_MESSAGES=18
BALANCE_GUARDED_CONTEXT_CHARS=1800
BALANCE_GUARDED_OUTPUT_TOKENS=900
BALANCE_GUARDED_REFLECTION_TOKENS=480
BALANCE_GUARDED_PLANNER_TOKENS=400
WEB_SEARCH_ENABLED=true
WEB_SEARCH_BASE_URL=https://html.duckduckgo.com/html/
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_USER_AGENT=Mozilla/5.0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.85

# Optional local-only Markdown context directory.
# Empty uses backend/private_context; put custom paths in .env.local.
PRIVATE_CONTEXT_DIR=
PRIVATE_CONTEXT_ALLOW_REMOTE=false

# Optional read-only Markdown workspace, reloaded on every relevant request.
WORKSPACE_CONTEXT_DIR=

# OpenAI API mode:
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEMPERATURE=0.7
