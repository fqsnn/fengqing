AI_PROVIDER=ollama
APP_HOST=127.0.0.1
APP_PORT=8000
LLM_TIMEOUT_SECONDS=120
WEB_SEARCH_ENABLED=true
WEB_SEARCH_BASE_URL=https://html.duckduckgo.com/html/
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_USER_AGENT=Mozilla/5.0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.85

# Optional local-only Markdown context directory.
# Empty uses backend/private_context; put custom paths in .env.local.
PRIVATE_CONTEXT_DIR=
PRIVATE_CONTEXT_ALLOW_REMOTE=false

# Optional read-only Markdown workspace, reloaded on every relevant request.
WORKSPACE_CONTEXT_DIR=

# OpenAI API mode:
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TEMPERATURE=0.7
